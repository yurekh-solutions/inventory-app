# Tubhyam Inventory AI - Environment Variables

# MongoDB Configuration (use MongoDB Atlas for production)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/tubhyam-inventory

# Server Configuration
PORT=3002
NODE_ENV=production

# WhatsApp Web.js - NO API KEY NEEDED
# Just scan the QR code shown in terminal on first run
# Session is saved automatically — no re-scan needed after first time

# Frontend URL (for CORS) - Update with your Vercel/Netlify URL
FRONTEND_URL=https://tubhyam.in
